# ─── Application ──────────────────────────────────────────────
APP_NAME=HireAI
APP_ENV=development
DEBUG=true
PORT=8000
USE_REDIS=false

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS S3 (Resume & Recording Storage) ──────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=hireai-uploads-prod

# LOCAL DEV ONLY: set these for local boto3 access to S3.
# On AWS ECS (production) these are intentionally left EMPTY —
# the ECS Task IAM Role (hireai-ecs-task) provides S3 access
# automatically via instance metadata. No keys needed in prod.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ─── Email — Resend SMTP ───────────────────────────────────────
# Resend works on AWS out of the box via the NAT Gateway.
# No SES setup or sandbox approval required.
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── JWT ──────────────────────────────────────────────────────
SECRET_KEY=generate-a-secure-random-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3002
# ALLOWED_ORIGINS=["http://localhost:3002","https://hiring.ashishai.in"]

# ─── Interview Settings ───────────────────────────────────────
MATCH_THRESHOLD=0.50
INTERVIEW_ROOM_EXPIRY=7200
MAX_INTERVIEW_DURATION=5400

# ─── Production Notes ─────────────────────────────────────────
# In production (AWS ECS), ALL secrets above are stored in
# AWS SSM Parameter Store (SecureString) and injected into the
# container at startup by the ECS Task Definition.
# You do NOT commit a .env file to your repo.
# See: infra/terraform/main.tf  (aws_ssm_parameter resources)
